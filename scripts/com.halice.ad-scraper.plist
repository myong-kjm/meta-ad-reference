<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd plist — 매일 오전 8시에 광고 스크래퍼 실행.

  설치:
    bash scripts/install_schedule.sh

  확인:
    launchctl list | grep halice

  제거:
    launchctl unload ~/Library/LaunchAgents/com.halice.ad-scraper.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.halice.ad-scraper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_PATH__/scripts/run_daily.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 노트북이 자고 있다가 깨어나면 못 실행한 거 한 번 따라잡기 -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__PROJECT_PATH__/data/logs/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>__PROJECT_PATH__/data/logs/launchd.err.log</string>

    <key>WorkingDirectory</key>
    <string>__PROJECT_PATH__</string>
</dict>
</plist>
